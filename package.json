{
	"name": "@commertize/token-contracts",
	"version": "1.0.0",
	"description": "Commertize smart contracts for real estate tokenization, debt instruments, and mortgage lending",
	"scripts": {
		"build": "hardhat build --no-typechain && tsup index.mts --format esm --dts --clean",
		"compile": "hardhat build",
		"test": "hardhat test",
		"node": "hardhat node",
		"clean": "hardhat clean",
		"deploy:localhost": "hardhat run --network localhost scripts/deploy.ts",
		"deploy:testnet": "hardhat run --network testnet scripts/deploy.ts",
		"deploy:mainnet": "hardhat run --network mainnet scripts/deploy.ts",
		"deploy:bridge:testnet": "hardhat run --network testnet scripts/deploy-bridge.ts",
		"deploy:bridge:base-sepolia": "hardhat run --network base-sepolia scripts/deploy-bridge.ts",
		"deploy:bridge:full": "hardhat run --network testnet scripts/deploy-full-bridge.ts",
		"test:testnet": "CI=true hardhat test test/TestnetValidation.ts --network testnet",
		"test:base-sepolia": "CI=true hardhat test test/TestnetValidation.ts --network base-sepolia",
		"release": "npx tsx scripts/release.ts"
	},
	"keywords": [
		"real-estate",
		"tokenization",
		"ERC-3643",
		"DeFi",
		"mortgage",
		"debt"
	],
	"author": "Commertize",
	"license": "MIT",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"deployment.*.json",
		"artifacts/src/**/*.json",
		"!artifacts/build-info"
	],
	"exports": {
		".": {
			"development": "./index.mts",
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./deployment.json": "./deployment.testnet.json",
		"./deployment.testnet.json": "./deployment.testnet.json",
		"./deployment.mainnet.json": "./deployment.mainnet.json",
		"./deployment.localhost.json": "./deployment.localhost.json",
		"./deployment.base_sepolia.json": "./deployment.base_sepolia.json",
		"./artifacts/*": "./artifacts/src/*"
	},
	"type": "module",
	"packageManager": "pnpm@9.15.4",
	"devDependencies": {
		"@nomicfoundation/hardhat-ethers": "^4.0.0",
		"@nomicfoundation/hardhat-ethers-chai-matchers": "^3.0.0",
		"@nomicfoundation/hardhat-ignition": "^3.0.0",
		"@nomicfoundation/hardhat-ignition-ethers": "^3.0.0",
		"@nomicfoundation/hardhat-keystore": "^3.0.0",
		"@nomicfoundation/hardhat-mocha": "^3.0.0",
		"@nomicfoundation/hardhat-network-helpers": "^3.0.0",
		"@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.0",
		"@nomicfoundation/hardhat-typechain": "^3.0.0",
		"@nomicfoundation/hardhat-verify": "^3.0.0",
		"@nomicfoundation/ignition-core": "^3.0.0",
		"@openzeppelin/contracts": "^5.1.0",
		"@types/node": "^25.0.9",
		"chai": "^5.1.2",
		"chalk": "^4.1.2",
		"hardhat": "^3.0.0",
		"mocha": "^11.0.0",
		"prompts": "^2.4.2",
		"tsx": "^4.19.0",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@commertize/utils": "workspace:*",
		"@layerzerolabs/lz-evm-oapp-v2": "^3.0.154",
		"@layerzerolabs/lz-evm-protocol-v2": "^3.0.154",
		"@openzeppelin/contracts-upgradeable": "^5.4.0",
		"dotenv": "^17.2.3",
		"ethers": "^6.16.0"
	}
}
