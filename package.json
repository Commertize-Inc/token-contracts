{
	"name": "@commertize/token-contracts",
	"version": "1.0.0",
	"description": "Commertize smart contracts for real estate tokenization, debt instruments, and mortgage lending",
	"scripts": {
		"build": "hardhat build --no-typechain && tsup index.mts --format esm --dts --clean",
		"compile": "hardhat build",
		"test": "hardhat test",
		"node": "hardhat node",
		"clean": "hardhat clean",
		"deploy:localhost": "hardhat run --network localhost scripts/deploy.ts",
		"deploy:arc-testnet": "hardhat run --network arc-testnet scripts/deploy.ts",
		"deploy:mainnet": "hardhat run --network mainnet scripts/deploy.ts",
		"test:arc-testnet": "CI=true hardhat test test/TestnetValidation.ts --network arc-testnet",
		"test:arc-integration": "CI=true hardhat test test/IntegrationFlows.ts --network arc-testnet",
		"test:arc-crosschain": "CI=true hardhat test test/CrossChainCCIP.ts --network arc-testnet",
		"release": "npx tsx scripts/release.ts"
	},
	"keywords": [
		"real-estate",
		"tokenization",
		"ERC-3643",
		"DeFi",
		"mortgage",
		"debt"
	],
	"author": "Commertize",
	"license": "MIT",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"deployment.*.json",
		"artifacts/src/**/*.json",
		"!artifacts/build-info"
	],
	"exports": {
		".": {
			"development": "./index.mts",
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./deployment.json": "./deployment.arc_testnet.json",
		"./deployment.arc_testnet.json": "./deployment.arc_testnet.json",
		"./deployment.mainnet.json": "./deployment.mainnet.json",
		"./deployment.localhost.json": "./deployment.localhost.json",
		"./artifacts/*": "./artifacts/src/*"
	},
	"type": "module",
	"packageManager": "pnpm@9.15.4",
	"devDependencies": {
		"@nomicfoundation/hardhat-ethers": "^4.0.6",
		"@nomicfoundation/hardhat-ethers-chai-matchers": "^3.0.3",
		"@nomicfoundation/hardhat-ignition": "^3.1.0",
		"@nomicfoundation/hardhat-ignition-ethers": "^3.1.0",
		"@nomicfoundation/hardhat-keystore": "^3.0.5",
		"@nomicfoundation/hardhat-mocha": "^3.0.14",
		"@nomicfoundation/hardhat-network-helpers": "^3.0.4",
		"@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.3",
		"@nomicfoundation/hardhat-typechain": "^3.0.4",
		"@nomicfoundation/hardhat-verify": "^3.0.12",
		"@nomicfoundation/ignition-core": "^3.1.0",
		"@openzeppelin/contracts": "^5.6.1",
		"chai": "^6.2.2",
		"chalk": "^5.6.2",
		"hardhat": "^3.2.0",
		"mocha": "^11.7.5",
		"prompts": "^2.4.2"
	},
	"dependencies": {
		"@commertize/utils": "workspace:*",
		"@openzeppelin/contracts-upgradeable": "^5.6.1",
		"dotenv": "^17.3.1",
		"ethers": "^6.16.0"
	}
}
