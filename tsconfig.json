{
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": ".",
		"moduleResolution": "bundler",
		"target": "ES2022",
		"module": "ES2022",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true
	},
	"include": ["index.mts", "src/**/*"],
	"exclude": ["node_modules", "dist"]
}
