{
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": ".",
		"moduleResolution": "bundler",
		"target": "ES2022",
		"module": "esnext",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"strict": false
	},
	"include": [
		"index.mts",
		"src/**/*",
		"test/**/*",
		"hardhat.config.ts",
		"scripts/**/*"
	],
	"exclude": ["node_modules", "dist"]
}
