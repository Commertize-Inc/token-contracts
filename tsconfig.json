{
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": ".",
		"moduleResolution": "node16",
		"target": "ES2022",
		"module": "node16",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"strict": false
	},
	"include": [
		"index.mts",
		"src/**/*",
		"test/**/*",
		"hardhat.config.ts",
		"scripts/**/*"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}
