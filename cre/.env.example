# Copy to cre/.env and fill in. cre/.env is gitignored — never commit real values.

# Funded EOA that broadcasts simulate --broadcast / deploy txs (64 hex chars, no 0x).
CRE_ETH_PRIVATE_KEY=

# RPC endpoints referenced by project.yaml.
ETH_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
BASE_SEPOLIA_RPC_URL=https://base-sepolia-rpc.publicnode.com
ETH_MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com

# Secret consumed by the workflow (referenced from secrets.yaml).
NAV_API_KEY=
